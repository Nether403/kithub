{
  "name": "@kithub/db",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "check-types": "tsc --noEmit",
    "migrate": "drizzle-kit push",
    "push": "drizzle-kit push",
    "generate": "drizzle-kit generate",
    "seed": "tsx src/seed.ts",
    "seed:skills": "tsx src/seed-skills.ts",
    "seed:journeykits": "tsx src/seed-journeykits.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.3.3"
  }
}
