modules = ["web", "bash", "nodejs-20", "python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev -- --filter=web"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c 'set -a; [ -f .env ] && source .env; set +a; npm run dev -- --filter=api'"
waitForPort = 8080

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 24678
externalPort = 3000

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[userenv]

[userenv.shared]
WEB_URL = "https://98994a5b-5bd7-4289-b136-812522f5eb53-00-1q8u9pntvmsvs.riker.replit.dev"
NEXT_PUBLIC_API_URL = "https://98994a5b-5bd7-4289-b136-812522f5eb53-00-1q8u9pntvmsvs.riker.replit.dev"
NEXT_PUBLIC_BASE_URL = "https://98994a5b-5bd7-4289-b136-812522f5eb53-00-1q8u9pntvmsvs.riker.replit.dev"
NODE_ENV = "development"
PORT = "8080"

[deployment]
deploymentTarget = "cloudrun"
