# SkillKitHub — Environment Variables
# Copy this file to .env and fill in the values.

# ═══════════════════════════════════════════════════════════════
# REQUIRED
# ═══════════════════════════════════════════════════════════════

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/kithub

# JWT signing secret (MUST be set in production)
JWT_SECRET=your-secret-key-here

# ═══════════════════════════════════════════════════════════════
# OPTIONAL
# ═══════════════════════════════════════════════════════════════

# Frontend URL (for CORS and email links)
WEB_URL=http://localhost:5000

# Node environment: development | production
NODE_ENV=development

# API port (default: 8080)
PORT=8080

# ── Email Delivery ──────────────────────────────────────────────
# SMTP connection string. If not set, verification codes print to console.
# Example: smtps://user:pass@smtp.example.com:465
# SMTP_URL=
# EMAIL_FROM=noreply@kithub.dev

# ── Replit-specific ─────────────────────────────────────────────
# Automatically set by Replit — do not set manually
# REPLIT_DEV_DOMAIN=
