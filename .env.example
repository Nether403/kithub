# SkillKitHub — Environment Variables
# Copy this file to .env and fill in the values.

# ═══════════════════════════════════════════════════════════════
# DATABASE (Neon Postgres)
# Create a project at https://neon.tech and grab the pooled connection string.
# Use the "Connection string" from your Neon dashboard.
# ═══════════════════════════════════════════════════════════════

# Pooled connection string from Neon
# Format: postgresql://neondb_owner:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://neondb_owner:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# ═══════════════════════════════════════════════════════════════
# AUTHENTICATION (Supabase)
# ═══════════════════════════════════════════════════════════════

# Supabase project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Public Supabase URL for the web app / browser client
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Server-side key for API auth verification and admin lookups
# Use the Supabase service role key.
SUPABASE_SECRET_KEY=sb_secret_your_server_key_here

# Public browser key for the web app
# Use your Supabase anon or publishable key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key_here

# ═══════════════════════════════════════════════════════════════
# APP URLS
# ═══════════════════════════════════════════════════════════════

# Web frontend URL (used for CORS and email links)
# Local dev:      http://localhost:5000
# Vercel:         https://skillkithub.vercel.app
WEB_URL=http://localhost:5000

# API base URL (used by the web frontend to reach the API)
# Local dev:      http://localhost:8080
# Railway:        https://your-app.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8080

# Public base URL for metadata / OG image links
# Local dev:      http://localhost:5000
# Vercel:         https://skillkithub.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:5000

# ═══════════════════════════════════════════════════════════════
# RUNTIME
# ═══════════════════════════════════════════════════════════════

# Node environment: development | production
NODE_ENV=development

# API port (default: 8080)
PORT=8080

# Shared secret for narrow admin API operations, such as publisher verification.
# Set this only on trusted API environments and send it as the x-admin-secret header.
# ADMIN_API_SECRET=

# ═══════════════════════════════════════════════════════════════
# SEMANTIC SEARCH (Optional)
# Enables embedding-based semantic search and related-kits.
# Falls back to keyword/tag matching when none are set.
# Set ONE of these — first available wins.
# Priority: Gemini → OpenAI → OpenRouter → Azure OpenAI
# ═══════════════════════════════════════════════════════════════

# Option 1: Google Gemini (recommended — cheapest, 768-dim text-embedding-004)
# GEMINI_API_KEY=AIza...

# Option 2: OpenAI (direct — 1536-dim text-embedding-3-small)
# OPENAI_API_KEY=sk-...

# Option 3: OpenRouter (OpenAI-compatible proxy — 1536-dim)
# OPENROUTER_API_KEY=sk-or-...

# Option 4: Azure OpenAI (enterprise — 1536-dim)
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
# AZURE_OPENAI_API_VERSION=2024-02-01

# ═══════════════════════════════════════════════════════════════
# EMAIL DELIVERY (Optional)
# Without this, verification codes print to the server console
# ═══════════════════════════════════════════════════════════════

# SMTP connection string (nodemailer format)
# Resend:    smtps://resend:[API_KEY]@smtp.resend.com:465
# SendGrid:  smtps://apikey:[API_KEY]@smtp.sendgrid.net:465
# SMTP_URL=

# From address for outbound emails
# EMAIL_FROM=noreply@skillkithub.com

# ═══════════════════════════════════════════════════════════════
# ERROR TRACKING (Optional)
# ═══════════════════════════════════════════════════════════════

# Sentry DSN for error tracking (apps/web + apps/api)
# SENTRY_DSN=

# ═══════════════════════════════════════════════════════════════
# CLI (Optional)
# ═══════════════════════════════════════════════════════════════

# Override the API base URL used by packages/cli and packages/sdk
# KITHUB_API_URL=http://localhost:8080

# Optional frontend base URL used by CLI publish output
# KITHUB_WEB_URL=http://localhost:5000

# Optional bearer token override for CLI requests.
# Prefer `kithub login` for a refreshable local session.
# KITHUB_TOKEN=
