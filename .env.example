# SkillKitHub — Environment Variables
# Copy this file to .env and fill in the values.

# ═══════════════════════════════════════════════════════════════
# DATABASE (Supabase)
# Find these in: Supabase Dashboard → Project → Settings → Database
# ═══════════════════════════════════════════════════════════════

# Full connection string (use "Session pooler" URI from Supabase for serverless)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# OR set individual PG vars (Supabase → Settings → Database → Connection parameters)
# PGHOST=aws-0-us-east-1.pooler.supabase.com
# PGPORT=5432
# PGDATABASE=postgres
# PGUSER=postgres.[project-ref]
# PGPASSWORD=your-db-password

# ═══════════════════════════════════════════════════════════════
# AUTHENTICATION (Supabase)
# ═══════════════════════════════════════════════════════════════

# Supabase project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Preferred public URL for the web app / browser client
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Server-side key for API auth verification and admin lookups
# Use the Supabase secret key (`sb_secret_...`) or service role key.
SUPABASE_SECRET_KEY=sb_secret_your_server_key_here

# Preferred public browser key for the web app
# Use your Supabase anon or publishable key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key_here

# Optional fallback names supported by the current app code
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_your_key_here
# SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ═══════════════════════════════════════════════════════════════
# APP URLS
# ═══════════════════════════════════════════════════════════════

# Web frontend URL (used for CORS and email links)
# Local dev:      http://localhost:5000
# Vercel deploy:  https://skillkithub.vercel.app
WEB_URL=http://localhost:5000

# API base URL (used by the web frontend to reach the API)
# Local dev:      http://localhost:8080
# Deployed API:   https://your-api-project.vercel.app
NEXT_PUBLIC_API_URL=http://localhost:8080

# Public base URL for metadata / OG image links in the web app
# Local dev:      http://localhost:5000
# Deployed web:   https://your-web-project.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:5000

# ═══════════════════════════════════════════════════════════════
# RUNTIME
# ═══════════════════════════════════════════════════════════════

# Node environment: development | production
NODE_ENV=development

# API port (default: 8080)
PORT=8080

# ═══════════════════════════════════════════════════════════════
# EMAIL DELIVERY (Optional)
# Without this, verification codes print to the server console
# ═══════════════════════════════════════════════════════════════

# SMTP connection string (nodemailer format)
# Example with Resend:    smtps://resend:[API_KEY]@smtp.resend.com:465
# Example with SendGrid:  smtps://apikey:[API_KEY]@smtp.sendgrid.net:465
# SMTP_URL=

# From address for outbound emails
# EMAIL_FROM=noreply@skillkithub.com

# ═══════════════════════════════════════════════════════════════
# CLI (Optional)
# ═══════════════════════════════════════════════════════════════

# Override the API base URL used by packages/cli and packages/sdk
# KITHUB_API_URL=http://localhost:8080

# Optional frontend base URL used by CLI publish output
# KITHUB_WEB_URL=http://localhost:5000

# Optional bearer token override for CLI requests.
# Prefer `kithub login` for a refreshable local session; use this only for explicit overrides.
# If set, this should be a Supabase access token.
# KITHUB_TOKEN=

# ═══════════════════════════════════════════════════════════════
# REPLIT-SPECIFIC (set automatically — do not set manually)
# ═══════════════════════════════════════════════════════════════
# REPLIT_DEV_DOMAIN=
