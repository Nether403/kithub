# SkillKitHub — Environment Variables
# Copy this file to .env and fill in the values.

# ═══════════════════════════════════════════════════════════════
# DATABASE (Supabase)
# Find these in: Supabase Dashboard → Project → Settings → Database
# ═══════════════════════════════════════════════════════════════

# Full connection string (use "Session pooler" URI from Supabase for serverless)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# OR set individual PG vars (Supabase → Settings → Database → Connection parameters)
# PGHOST=aws-0-us-east-1.pooler.supabase.com
# PGPORT=5432
# PGDATABASE=postgres
# PGUSER=postgres.[project-ref]
# PGPASSWORD=your-db-password

# ═══════════════════════════════════════════════════════════════
# AUTHENTICATION
# ═══════════════════════════════════════════════════════════════

# JWT signing secret — MUST be set in production (generate: openssl rand -hex 32)
JWT_SECRET=your-secret-key-here

# ═══════════════════════════════════════════════════════════════
# APP URLS
# ═══════════════════════════════════════════════════════════════

# Web frontend URL (used for CORS and email links)
# Local dev:      http://localhost:5000
# Vercel deploy:  https://skillkithub.vercel.app
WEB_URL=http://localhost:5000

# API base URL (used by the web frontend to reach the API)
# Local dev:      http://localhost:8080
# Deployed API:   https://your-api-host.railway.app (or Vercel serverless URL)
NEXT_PUBLIC_API_URL=http://localhost:8080

# ═══════════════════════════════════════════════════════════════
# RUNTIME
# ═══════════════════════════════════════════════════════════════

# Node environment: development | production
NODE_ENV=development

# API port (default: 8080)
PORT=8080

# ═══════════════════════════════════════════════════════════════
# EMAIL DELIVERY (Optional)
# Without this, verification codes print to the server console
# ═══════════════════════════════════════════════════════════════

# SMTP connection string (nodemailer format)
# Example with Resend:    smtps://resend:[API_KEY]@smtp.resend.com:465
# Example with SendGrid:  smtps://apikey:[API_KEY]@smtp.sendgrid.net:465
# SMTP_URL=

# From address for outbound emails
# EMAIL_FROM=noreply@skillkithub.com

# ═══════════════════════════════════════════════════════════════
# REPLIT-SPECIFIC (set automatically — do not set manually)
# ═══════════════════════════════════════════════════════════════
# REPLIT_DEV_DOMAIN=
